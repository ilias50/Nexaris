# =====================================================================
# Nexaris environment template
# Copy this file to .env and replace placeholder values for your setup.
# Do not commit the real .env file to GitHub.
# =====================================================================

# ---------------------------------------------------------------------
# Database credentials
# ---------------------------------------------------------------------
# Root password used by the MySQL container for initialization/admin tasks.
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# Application DB user used by backend services to connect to their schemas.
SPRING_DATASOURCE_USERNAME=CHANGE_ME_APP_DB_USER
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_APP_DB_PASSWORD

# ---------------------------------------------------------------------
# Database names (one schema per service)
# ---------------------------------------------------------------------
AUTH_DB_NAME=nexaris_authservice
ORG_DB_NAME=nexaris_orgservice
PLANNING_DB_NAME=nexaris_planningservice
HOLIDAY_PROXY_DB_NAME=nexaris_holidayproxyservice
NOTIFICATION_DB_NAME=nexaris_notificationservice

# ---------------------------------------------------------------------
# JDBC URLs for each backend service
# Adapt host/port if DB runs on another machine or container name.
# ---------------------------------------------------------------------
AUTH_DB_URL=jdbc:mysql://nexaris-db:3306/nexaris_authservice?createDatabaseIfNotExist=true
ORG_DB_URL=jdbc:mysql://nexaris-db:3306/nexaris_orgservice?createDatabaseIfNotExist=true
PLANNING_DB_URL=jdbc:mysql://nexaris-db:3306/nexaris_planningservice?createDatabaseIfNotExist=true
HOLIDAY_PROXY_DB_URL=jdbc:mysql://nexaris-db:3306/nexaris_holidayproxyservice?createDatabaseIfNotExist=true
NOTIFICATION_DB_URL=jdbc:mysql://nexaris-db:3306/nexaris_notificationservice?createDatabaseIfNotExist=true

# ---------------------------------------------------------------------
# Internal security secrets
# ---------------------------------------------------------------------
# Shared secret used by internal gateway filters.
GATEWAY_INTERNAL_SECRET=CHANGE_ME_INTERNAL_SECRET

# Service-to-service token for trusted internal calls.
SERVICE_TOKEN=CHANGE_ME_SERVICE_TOKEN

# JWT signing secret and expirations (milliseconds).
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ---------------------------------------------------------------------
# Bootstrap admin account (first startup)
# ---------------------------------------------------------------------
APP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
APP_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
APP_BOOTSTRAP_ADMIN_FIRST_NAME=System
APP_BOOTSTRAP_ADMIN_LAST_NAME=Admin

# ---------------------------------------------------------------------
# Service URLs used by backend and frontend
# Change these when hostnames or ports differ by installation.
# ---------------------------------------------------------------------
VITE_API_URL=http://localhost:8080/api/v1
GATEWAY_URL=http://gateway:8080
NOTIFICATION_SERVICE_URL=http://notification-service:8080
NOTIFICATION_EMAIL_ENDPOINT=/api/v1/notifications/email

# Gateway route target URIs (used by gateway service).
AUTH_SERVICE_URI=http://auth-service:8080
NOTIFICATION_SERVICE_URI=http://notification-service:8080
ORG_SERVICE_URI=http://org-service:8080
HOLIDAY_PROXY_SERVICE_URI=http://holiday-proxy-service:8080
PLANNING_SERVICE_URI=http://planning-service:8080

# ---------------------------------------------------------------------
# Holiday external provider configuration
# ---------------------------------------------------------------------
HOLIDAY_EXTERNAL_BASE_URL=https://date.nager.at
HOLIDAY_EXTERNAL_PUBLIC_HOLIDAYS_PATH=/api/v3/PublicHolidays/{year}/{countryCode}

# ---------------------------------------------------------------------
# SMTP / email sending configuration
# ---------------------------------------------------------------------
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=example@example.com
SPRING_MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_TRUST=*
NOTIFICATION_MAIL_DEFAULT_FROM=no-reply@example.com